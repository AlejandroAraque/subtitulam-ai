# Python-generated files
__pycache__/
*.py[oc]
*.py[cod]
*$py.class
build/
dist/
wheels/
*.egg-info

# Entornos virtuales de Python
.venv/
venv/
env/
*.pyc

# Variables de entorno y secretos (¡CRÍTICO!)
.env

# Archivos del sistema operativo (Mac)
.DS_Store

# Archivos de la base de datos local (si los añades en el futuro)
*.db
*.sqlite3

# Almacén vectorial de ChromaDB (legacy v2.x, SQLite + binarios internos, no versionar)
data/chromadb/

# Almacén vectorial de Qdrant (v3.0+, volumen Docker persistente, no versionar)
data/qdrant_storage/

# Memoria del TFM — notas personales que viven solo en local
docs/memoria/

# Archivos temporales de descarga (para que no subas los SRT de prueba)
*.srt
*.mp4

# Excepciones: artefactos de runs canónicos (baseline, comparativas) sí se versionan
!data/baseline_run/*.srt
!data/baseline_run/*.mp4
# Excepción: el SRT de prueba canónico se versiona como referencia del corpus
!data/test_sample_en.srt
!data/testset/**/*.srt