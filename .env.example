# Plantilla de variables de entorno.
# Copia este archivo a `.env` y rellena los valores reales.
# El `.env` está gitignored — nunca subas tus claves.

# ── OpenAI ────────────────────────────────────────────────────────────
# Imprescindible. Necesita acceso a gpt-4o + text-embedding-3-small.
OPENAI_API_KEY=sk-...

# ── Qdrant (opcional — solo si usas Qdrant Cloud o un host externo) ──
# Para self-hosted local con docker compose, dejar comentado: el
# docker-compose.yml ya inyecta QDRANT_URL=http://qdrant:6333.
# Para Qdrant Cloud, descomentar y rellenar ambas:
# QDRANT_URL=https://xyz-abc.eu-central.aws.cloud.qdrant.io:6333
# QDRANT_API_KEY=sk-qdrant-...

# ── Modelo (opcional, defaults razonables) ────────────────────────────
# OPENAI_MODEL=gpt-4o
# OPENAI_TEMPERATURE=0.3
# OPENAI_MAX_TOKENS=800

# ── Traducción (opcional) ─────────────────────────────────────────────
# DEFAULT_CHUNK_SIZE=5
# DEFAULT_CPL_LIMIT=42
# DEFAULT_TARGET_LANG=es
